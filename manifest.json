{
  "manifest_version": 3,
  "name": "SonarQube PR Analyzer",
  "version": "2.0",
  "description": "View SonarQube analysis results directly from GitHub PR pages",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "permissions": ["sidePanel", "storage", "activeTab", "tabs"],
  "optional_host_permissions": ["https://*/*", "http://localhost/*"],
  "host_permissions": ["https://github.com/*"],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "SonarQube PR Analyzer",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}